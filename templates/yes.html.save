<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Yes! 💖</title>
    <style>
        body {
            font-family: 'Comic Sans MS', cursive, sans-serif;
            text-align: center;
            margin: 0;
            height: 100vh;
            background: linear-gradient(rgba(255,192,203,0.7), rgba(255,105,180,0.7)),
                        url('../static/pics/us.jpg') no-repeat center center fixed;
            background-size: cover;
            overflow: hidden;
            position: relative;
            color: white;
        }
        h1 {
            margin-top: 50px;
            font-size: 3rem;
            text-shadow: 2px 2px 8px rgba(0,0,0,0.3);
        }
        p {
            font-size: 1.8rem;
            margin-top: 20px;
            text-shadow: 1px 1px 5px rgba(0,0,0,0.3);
        }
        img {
            margin-top: 30px;
            border-radius: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
        }

        @keyframes float {
            0% { transform: translateY(0); opacity: 1; }
            100% { transform: translateY(-600px); opacity: 0; }
        }
        .heart {
            position: absolute;
            font-size: 24px;
            animation: float 5s linear infinite;
        }
    </style>
</head>
<body>

    <h1>Yay! You said YES! 💖🎉</h1>
    <p>Thank you for making me the happiest person ever 😍</p>
    <img src="../static/pics/us.jpg" alt="Us" width="300px">

    <!-- Confetti -->
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script>
        confetti({
            particleCount: 150,
            spread: 70,
            origin: { y: 0.6 }
        });
    </script>

    <!-- Floating hearts -->
    <script>
        const colors = ["❤️","💖","💘","💝","💕"];
        for(let i=0;i<30;i++){
            let heart = document.createElement("div");
            heart.className = "heart";
            heart.style.left = Math.random() * window.innerWidth + "px";
            heart.style.animationDuration = 3 + Math.random() * 5 + "s";
            heart.innerText = colors[Math.floor(Math.random()*colors.length)];
            document.body.appendChild(heart);
        }
    </script>

</body>
</html>
